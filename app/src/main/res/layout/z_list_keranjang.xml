<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="wrap_content"
    android:layout_width="match_parent"
    android:layout_marginBottom="20dp">

    <RelativeLayout
        android:id="@+id/rl1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:padding="15dp">

    <ImageView
        android:id="@+id/checkBox"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_checkbox_unchecked"/>

    <TextView
        android:id="@+id/namaToko"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Toko Pupuk Sejahtera"
        android:textColor="@color/black"
        android:fontFamily="@font/inter_bold"
        android:textSize="12sp"
        android:layout_marginLeft="10sp"
        android:layout_toRightOf="@id/checkBox"/>


    <ImageView
        android:id="@+id/imgWarung"
        android:layout_width="40dp"
        android:layout_height="50dp"
        android:layout_marginLeft="5dp"
        android:background="@drawable/img_event"
        android:scaleType="centerCrop"
        android:layout_below="@id/namaToko"
        android:layout_alignStart="@id/namaToko"
        android:layout_marginTop="10sp"/>

    <TextView
        android:id="@+id/namaProduk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Traktor Tipe C"
        android:fontFamily="@font/inter_regular"
        android:textColor="@color/black"
        android:textSize="12sp"
        android:layout_alignTop="@id/imgWarung"
        android:layout_marginLeft="10dp"
        android:layout_toRightOf="@id/imgWarung" />

    <TextView
        android:id="@+id/biayaProduk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rp. 250.000"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="10dp"
        android:layout_alignTop="@id/namaProduk"
        android:layout_marginTop="5dp"
        android:fontFamily="@font/inter_bold"
        android:textColor="#16672E"
        android:textSize="12sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="10dp"
            android:layout_below="@id/biayaProduk"
            android:gravity="center_vertical|right"
            android:layout_marginTop="5dp">
            <FrameLayout
                android:id="@+id/btnMinus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/ic_circle_gray">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_cart_minus"
                    android:padding="5dp"/>
            </FrameLayout>

            <TextView
                android:id="@+id/jmlPesanan"
                android:layout_marginHorizontal="12dp"
                android:text="1"
                android:fontFamily="@font/inter_bold"
                android:textColor="#16672E"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <FrameLayout
                android:id="@+id/btnAdd"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/ic_circle_gray">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_cart_add"
                    android:padding="5dp"/>
            </FrameLayout>
        </LinearLayout>

    </RelativeLayout>

    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_below="@id/rl1"
        android:layout_height="5dp"
        android:layout_marginTop="5dp"
        android:background="#D9D9D9"/>

</RelativeLayout>
